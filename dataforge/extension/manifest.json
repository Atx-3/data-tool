{
    "manifest_version": 3,
    "name": "DataForge - LinkedIn Data Capture",
    "version": "1.0",
    "description": "Capture LinkedIn profile data with one click and send to DataForge dashboard",
    "permissions": [
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "https://www.linkedin.com/*",
        "http://localhost:3001/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.linkedin.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ]
        }
    ],
    "icons": {
        "128": "icon128.png"
    }
}